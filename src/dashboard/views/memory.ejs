<%- include('layout', { path: '/dashboard/memory' }) %>
<div class="card">
  <h3>User Memory Viewer</h3>
  <form method="GET" action="/dashboard/memory" id="memoryForm">
    <div class="contact-picker">
      <label>Select User</label>
      <% const selectedContact = jid ? contacts.find(c => c.jid === jid) : null; %>
      <% const selectedLabel = selectedContact ? (selectedContact.displayName || selectedContact.phoneNumber || selectedContact.pushName || jid.split('@')[0] || jid) : ''; %>
      <input type="text" id="contactSearch" placeholder="Search contacts..." autocomplete="off" value="<%= selectedLabel %>">
      <input type="hidden" id="jid" name="jid" value="<%= jid || '' %>">
      <div id="contactDropdown" class="contact-dropdown" style="display:none"></div>
    </div>
  </form>
</div>

<script>
function contactLabel(c) { return c.displayName || c.phoneNumber || c.pushName || c.jid?.split('@')[0] || 'Unknown'; }
const contacts = <%- JSON.stringify(contacts || []) %>;
createContactPicker('#contactSearch', '#jid', '#contactDropdown', contacts, {
  onSelect: () => get('#memoryForm').submit()
});
</script>

<% if (jid) { %>
  <div class="card">
    <h3>Memory Context</h3>
    <% if (memory) { %><pre><%= memory %></pre><% } else { %><p class="text-muted">No memory stored.</p><% } %>
  </div>
  <div class="card">
    <h3>Recent Messages</h3>
    <% if (!messages || messages.length === 0) { %><p class="text-muted">No messages.</p>
    <% } else { %>
      <div class="msg-list">
        <% messages.slice().reverse().forEach(m => { %>
          <div class="msg-item">
            <span class="role <%= m.role %>"><%= m.role %></span>
            <span class="time"><%= m.timestamp ? new Date(parseInt(m.timestamp)).toLocaleString() : '' %></span>
            <div class="text"><%= m.text %></div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
<% } %>
</div></div>
<script src="/static/script.js"></script>
</body></html>
