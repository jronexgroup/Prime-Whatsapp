<%- include('layout', { path: '/dashboard/chat' }) %>
<div class="card">
  <h3>Send Message</h3>
  <form id="sendForm">
    <div class="contact-picker">
      <label>Recipient</label>
      <input type="text" id="contactSearch" placeholder="Search contacts or type a number..." autocomplete="off">
      <input type="hidden" id="jid" name="jid">
      <div id="contactDropdown" class="contact-dropdown" style="display:none"></div>
    </div>
    <label>Message</label>
    <textarea id="message" rows="4" placeholder="Type your message..." required></textarea>
    <button type="submit">Send Now</button>
  </form>
</div>

<script>
const contacts = <%- JSON.stringify(contacts || []) %>;
createContactPicker('#contactSearch', '#jid', '#contactDropdown', contacts);

get('#sendForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const jid = get('#jid').value;
  if (!jid) { showToast('Select a recipient first', 'error'); return; }
  const btn = e.target.querySelector('button');
  btn.disabled = true; btn.textContent = 'Sending...';
  const r = await fetch('/dashboard/chat/send', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ jid, message: get('#message').value }),
  });
  btn.disabled = false; btn.textContent = 'Send Now';
  if (r.ok) { showToast('Message sent!'); get('#message').value = ''; get('#jid').value = ''; get('#contactSearch').value = ''; }
  else { const d = await r.json().catch(() => ({})); showToast(d.error || 'Failed', 'error'); }
});
</script>
</div></div>
<script src="/static/script.js"></script>
</body></html>
