<%- include('layout', { path: '/dashboard/broadcast' }) %>
<div class="card">
  <h3>New Broadcast</h3>
  <form id="broadcastForm">
    <label>Campaign Name</label>
    <input type="text" id="name" placeholder="Weekly offer" required>
    <label>Message</label>
    <textarea id="message" rows="4" placeholder="Broadcast message..." required></textarea>
    <label>Recipients</label>
    <div class="contact-picker">
      <input type="text" id="contactSearch" placeholder="Search contacts to add..." autocomplete="off">
      <div id="contactDropdown" class="contact-dropdown" style="display:none"></div>
      <div id="recipientTags" class="contact-tags"></div>
    </div>
    <label>Scheduled (optional)</label>
    <input type="datetime-local" id="scheduledAt">
    <button type="submit">Create Broadcast</button>
  </form>
</div>

<div class="card">
  <h3>Broadcasts</h3>
  <% if (!broadcasts || broadcasts.length === 0) { %>
    <div class="empty">No broadcasts yet</div>
  <% } else { %>
    <table>
      <tr><th>Name</th><th>Recipients</th><th>Status</th><th>Actions</th></tr>
      <% broadcasts.forEach(b => { %>
        <tr>
          <td><%= b.name || 'Untitled' %></td>
          <td><%= (b.recipients || []).length %></td>
          <td><span class="badge <%= b.status === 'sent' ? 'connected' : 'pending' %>"><%= b.status || 'pending' %></span></td>
          <td>
            <% if (b.status !== 'sent') { %><button class="send-btn" data-id="<%= b.id %>" style="font-size:12px;padding:4px 10px">Send</button><% } %>
            <button class="del-btn" data-id="<%= b.id %>" style="font-size:12px;padding:4px 10px;background:#dc3545">Del</button>
          </td>
        </tr>
      <% }) %>
    </table>
  <% } %>
</div>

<script>
const contacts = <%- JSON.stringify(contacts || []) %>;
const bcSelected = [];
const picker = createContactPicker('#contactSearch', null, '#contactDropdown', contacts, {
  multiple: true,
  selected: bcSelected,
  tagsContainer: '#recipientTags',
});

get('#broadcastForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  if (!bcSelected.length) { showToast('Add recipients', 'error'); return; }
  const data = { name: get('#name').value, message: get('#message').value, recipients: bcSelected, status: 'pending', createdAt: Date.now().toString() };
  if (get('#scheduledAt').value) data.scheduledAt = new Date(get('#scheduledAt').value).getTime().toString();
  const r = await api('POST', '/api/broadcasts', data);
  if (r) { showToast('Created!'); location.reload(); }
});
document.querySelectorAll('.send-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (!confirm('Send now?')) return; btn.disabled = true;
    const r = await api('POST', `/api/broadcasts/${btn.dataset.id}/send`);
    if (r) showToast(`Sent ${r.sent}/${r.total}`);
    if (r?.ok) setTimeout(() => location.reload(), 1500);
  });
});
document.querySelectorAll('.del-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (!confirm('Delete?')) return;
    const r = await api('DELETE', `/api/broadcasts/${btn.dataset.id}`);
    if (r?.ok) { showToast('Deleted'); location.reload(); }
  });
});
</script>
</div></div>
<script src="/static/script.js"></script>
</body></html>
